#!/usr/bin/env bash
#
# route-tables.sh - bash-my-aws style functions for AWS Route Tables
#
# Usage: source route-tables.sh
#

# List all route tables with their routes
route-tables() {
  local filters=$@

  aws ec2 describe-route-tables \
    $([[ -n ${filters} ]] && echo --filters ${filters}) \
    --query "RouteTables[]" \
    --output json \
    | jq -r '.[] | 
    "# Route Table: \(.RouteTableId) | VPC: \(.VpcId) | Name: \((.Tags[]? | select(.Key=="Name") | .Value) // "N/A")",
    "DESTINATION\tTARGET\tSTATE",
    (.Routes[] | 
      [(.DestinationCidrBlock // .DestinationIpv6CidrBlock // .DestinationPrefixListId // "N/A"),
       (.GatewayId // .NatGatewayId // .TransitGatewayId // .VpcPeeringConnectionId // .NetworkInterfaceId // .InstanceId // "local"),
       .State] | 
      join("\t")),
    ""' \
    | while IFS= read -r line; do
      # Red highlight only the word "blackhole"
      if [[ $line =~ blackhole ]]; then
        echo "$line" | sed 's/blackhole/\x1b[1;31mblackhole\x1b[0m/g'
      # Yellow highlight only the public IP part
      elif [[ $line =~ ^([0-9]+\.[0-9]+\.[0-9]+\.[0-9]+(/[0-9]+)?) ]] \
        && [[ ! $line =~ ^10\. ]] \
        && [[ ! $line =~ ^192\.168\. ]] \
        && [[ ! $line =~ ^172\.(1[6-9]|2[0-9]|3[0-1])\. ]] \
        && [[ ! $line =~ ^169\.254\. ]] \
        && [[ ! $line =~ ^127\. ]]; then
        local ip="${BASH_REMATCH[1]}"
        echo "$line" | sed "s|^${ip}|\x1b[1;33m${ip}\x1b[0m|"
      else
        echo "$line"
      fi
    done
}

# List only route tables with public (non-RFC1918) routes
route-tables-public() {
  local filters=$@

  aws ec2 describe-route-tables \
    $([[ -n ${filters} ]] && echo --filters ${filters}) \
    --query "RouteTables[]" \
    --output json \
    | jq -r '.[] | 
    select(.Routes[] | 
      (.DestinationCidrBlock // "") | 
      test("^(?!10\\.|192\\.168\\.|172\\.(1[6-9]|2[0-9]|3[0-1])\\.|127\\.)") and test("^[0-9]")
    ) |
    "# Route Table: \(.RouteTableId) | VPC: \(.VpcId) | Name: \((.Tags[]? | select(.Key=="Name") | .Value) // "N/A")",
    "DESTINATION\tTARGET\tSTATE",
    (.Routes[] | 
      [(.DestinationCidrBlock // .DestinationIpv6CidrBlock // .DestinationPrefixListId // "N/A"),
       (.GatewayId // .NatGatewayId // .TransitGatewayId // .VpcPeeringConnectionId // .NetworkInterfaceId // .InstanceId // "local"),
       .State] | 
      join("\t")),
    ""' \
    | while IFS= read -r line; do
      # Red highlight only the word "blackhole"
      if [[ $line =~ blackhole ]]; then
        echo "$line" | sed 's/blackhole/\x1b[1;31mblackhole\x1b[0m/g'
      # Highlight non-RFC1918 destinations (public IPs)
      elif [[ $line =~ ^([0-9]+\.[0-9]+\.[0-9]+\.[0-9]+(/[0-9]+)?) ]] \
        && [[ ! $line =~ ^10\. ]] \
        && [[ ! $line =~ ^192\.168\. ]] \
        && [[ ! $line =~ ^172\.(1[6-9]|2[0-9]|3[0-1])\. ]] \
        && [[ ! $line =~ ^169\.254\. ]] \
        && [[ ! $line =~ ^127\. ]]; then
        local ip="${BASH_REMATCH[1]}"
        echo "$line" | sed "s|^${ip}|\x1b[1;33m${ip}\x1b[0m|"
      else
        echo "$line"
      fi
    done
}

# Show detailed information about specific route table(s)
route-table() {
  local route_table_ids=$(skim-stdin "$@")
  [[ -z $route_table_ids ]] && echo "Usage: route-table ROUTE_TABLE_ID [ROUTE_TABLE_ID...]" >&2 && return 1

  aws ec2 describe-route-tables \
    --route-table-ids $route_table_ids \
    --output json
}

# List routes for route table(s)
routes() {
  local route_table_ids=$(skim-stdin "$@")
  [[ -z $route_table_ids ]] && echo "Usage: routes ROUTE_TABLE_ID [ROUTE_TABLE_ID...]" >&2 && return 1

  for rtb_id in $route_table_ids; do
    echo "# Route Table: $rtb_id"
    aws ec2 describe-route-tables \
      --route-table-ids "$rtb_id" \
      --output text \
      --query "
        RouteTables[].Routes[].[
          DestinationCidrBlock,
          DestinationIpv6CidrBlock,
          GatewayId,
          NatGatewayId,
          TransitGatewayId,
          VpcPeeringConnectionId,
          NetworkInterfaceId,
          State
        ]" \
      | awk 'BEGIN {print "DESTINATION\tTARGET\tSTATE"} 
         {dest=$1; if($2!="None") dest=$2; 
          target=$3; 
          if($4!="None") target=$4;
          if($5!="None") target=$5;
          if($6!="None") target=$6;
          if($7!="None") target=$7;
          print dest"\t"target"\t"$8}' \
      | column -s$'\t' -t
    echo ""
  done
}

# List route tables by VPC
route-tables-by-vpc() {
  local vpc_ids=$(skim-stdin "$@")
  [[ -z $vpc_ids ]] && echo "Usage: route-tables-by-vpc VPC_ID [VPC_ID...]" >&2 && return 1

  for vpc_id in $vpc_ids; do
    echo "# VPC: $vpc_id"
    route-tables "Name=vpc-id,Values=$vpc_id"
    echo ""
  done
}

# Show subnet associations for route table(s)
route-table-subnets() {
  local route_table_ids=$(skim-stdin "$@")
  [[ -z $route_table_ids ]] && echo "Usage: route-table-subnets ROUTE_TABLE_ID [ROUTE_TABLE_ID...]" >&2 && return 1

  for rtb_id in $route_table_ids; do
    echo "# Route Table: $rtb_id"
    aws ec2 describe-route-tables \
      --route-table-ids "$rtb_id" \
      --output text \
      --query "
        RouteTables[].Associations[].[
          SubnetId,
          Main,
          AssociationState.State
        ]" \
      | awk 'BEGIN {print "SUBNET_ID\tMAIN\tSTATE"} 
         {print}' \
      | column -s$'\t' -t
    echo ""
  done
}

# Find route tables with a specific route destination
route-tables-with-destination() {
  local destination="$1"
  [[ -z $destination ]] && echo "Usage: route-tables-with-destination CIDR" >&2 && return 1

  aws ec2 describe-route-tables \
    --filters "Name=route.destination-cidr-block,Values=$destination" \
    --output text \
    --query "
      RouteTables[].[
        RouteTableId,
        VpcId,
        Tags[?Key=='Name'].Value | [0]
      ]" \
    | column -s$'\t' -t
}

# Find route tables with routes pointing to a specific target
route-tables-with-target() {
  local target="$1"
  [[ -z $target ]] && echo "Usage: route-tables-with-target TARGET_ID" >&2 && return 1

  # Determine target type and search accordingly
  local filter=""
  case "$target" in
    igw-*) filter="Name=route.gateway-id,Values=$target" ;;
    nat-*) filter="Name=route.nat-gateway-id,Values=$target" ;;
    tgw-*) filter="Name=route.transit-gateway-id,Values=$target" ;;
    pcx-*) filter="Name=route.vpc-peering-connection-id,Values=$target" ;;
    eni-*) filter="Name=route.network-interface-id,Values=$target" ;;
    *) echo "Unknown target type: $target" >&2 && return 1 ;;
  esac

  aws ec2 describe-route-tables \
    --filters "$filter" \
    --output text \
    --query "
      RouteTables[].[
        RouteTableId,
        VpcId,
        Tags[?Key=='Name'].Value | [0]
      ]" \
    | column -s$'\t' -t
}

# Show main route table for VPC(s)
route-table-main() {
  local vpc_ids=$(skim-stdin "$@")
  [[ -z $vpc_ids ]] && echo "Usage: route-table-main VPC_ID [VPC_ID...]" >&2 && return 1

  for vpc_id in $vpc_ids; do
    aws ec2 describe-route-tables \
      --filters "Name=vpc-id,Values=$vpc_id" "Name=association.main,Values=true" \
      --output text \
      --query "
        RouteTables[].[
          RouteTableId,
          VpcId,
          Tags[?Key=='Name'].Value | [0]
        ]" \
      | column -s$'\t' -t
  done
}

# Helper function to read from stdin or use arguments (bash-my-aws style)
skim-stdin() {
  if [[ -t 0 ]]; then
    echo "$@"
  else
    local stdin_data=$(cat)
    if [[ -n $stdin_data ]]; then
      echo "$stdin_data" | awk '{print $1}'
    else
      echo "$@"
    fi
  fi
}

# Export functions
export -f route-tables
export -f route-tables-public
export -f route-table
export -f routes
export -f route-tables-by-vpc
export -f route-table-subnets
export -f route-tables-with-destination
export -f route-tables-with-target
export -f route-table-main
export -f skim-stdin

# If script is executed (not sourced), run route-tables by default
if [[ ${BASH_SOURCE[0]} == "${0}" ]]; then
  route-tables "$@"
else
  echo "Route table functions loaded. Available commands:"
  echo "  route-tables                      - List all route tables"
  echo "  route-tables-public               - List only route tables with public routes"
  echo "  route-table ROUTE_TABLE_ID        - Show detailed route table info"
  echo "  routes ROUTE_TABLE_ID             - Show routes in route table"
  echo "  route-tables-by-vpc VPC_ID        - List route tables for VPC"
  echo "  route-table-subnets ROUTE_TABLE_ID - Show subnet associations"
  echo "  route-tables-with-destination CIDR - Find route tables with specific destination"
  echo "  route-tables-with-target TARGET_ID - Find route tables with specific target"
  echo "  route-table-main VPC_ID           - Show main route table for VPC"
fi
