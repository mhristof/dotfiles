#!/usr/bin/env bash
set -euo pipefail

ARG=${1:-}

case $ARG in
    m) AUTOMERGE=1 ;;
    -h | --help)
        echo "Usage: $0 [-h]"
        echo "  m: Merge automatically"
        echo "  -h: Show this help message"
        exit 0
        ;;
esac

if [[ -z ${GITLAB_TOKEN:-} ]]; then
    export GITLAB_TOKEN=$(/usr/bin/security find-generic-password -s germ -w -a GITLAB_TOKEN 2>/dev/null)
fi

description=""

jira=$(git rev-parse --abbrev-ref HEAD | grep -oP '^\w*-\d*')
if [[ -n "${jira}" ]]; then
    description="$(echo -e "$jira\n")"
fi

message=$(git --no-pager log --format=%b -n 1 "$(git rev-parse --verify HEAD)")
if [[ -n "${message}" ]]; then
    description="$(echo -e "$description\n$message")"
fi

if [[ -f .gitlab/merge_request_templates/Default.md ]]; then
    description="$description$(cat .gitlab/merge_request_templates/Default.md)"
fi

glab mr create \
    --description "$description" \
    --assignee "$(glab api /user | jq .username -r)" \
    --title "$(git-first-branch-commit.sh | head -1)" \
    --no-editor --push \
    --remove-source-branch \
    --yes || {
    # If MR already exists, that's okay - we'll continue to auto-merge if requested
    if ! glab mr view &>/dev/null; then
        # Only exit if there's no MR at all
        glab mr view | less --quit-if-one-screen
        exit 1
    fi
}

if [[ ${AUTOMERGE:-0} -eq 1 ]]; then
    echo "Setting merge when pipeline succeeds..."
    
    # Get the MR IID (internal ID) for the current branch
    mr_iid=$(glab mr list --source-branch "$(git rev-parse --abbrev-ref HEAD)" --json | jq '.[0].iid' 2>/dev/null)
    
    if [[ -z "$mr_iid" || "$mr_iid" == "null" ]]; then
        echo "ERROR: Could not find MR IID for current branch"
        glab mr view
        exit 1
    fi
    
    # Use GitLab API directly to set merge_when_pipeline_succeeds
    # This is the correct way instead of using the /merge endpoint
    if glab api --method PUT "/projects/:id/merge_requests/${mr_iid}" \
        --field merge_when_pipeline_succeeds=true \
        --field remove_source_branch=true \
        --silent; then
        echo "✓ MR will merge automatically when pipeline succeeds."
        glab mr view
    else
        echo ""
        echo "Could not set auto-merge. The MR will need to be merged manually."
        echo "This can happen if:"
        echo "  - Approvals are required"
        echo "  - Merge conflicts exist"
        echo "  - Protected branch rules prevent auto-merge"
        echo "  - Pipeline must pass first"
        echo ""
        glab mr view
    fi
fi
