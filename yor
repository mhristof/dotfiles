#!/usr/bin/env bash
set -euo pipefail

die() {
  echo "$1"
  exit 1
}

usage() {
  echo "Usage: $0 [-f] [-p]"
  echo "  -f: force push"
  echo "  -p: push"
  echo "  -C: dont commit"
  echo "  -V: git commit with --no-verify"
  exit 1
}

NO_VERIFY=""
COMMIT=1
args=$(getopt hfpCV "$@")
# shellcheck disable=SC2086
set -- $args
while :; do
  case "$1" in
    -V)
      NO_VERIFY="--no-verify"
      shift
      ;;
    -C)
      COMMIT=0
      shift
      ;;
    -f)
      FORCE=1
      shift
      ;;
    -p)
      PUSH=1
      shift
      ;;
    --)
      shift
      break
      ;;
    *)
      usage
      ;;
  esac
done

if [[ $COMMIT -eq 1 ]]; then
  if git status --porcelain ./*.tf | grep -q .; then
    die "Local changes detected, please commit them first"
  fi
fi

DEFAULT_BRANCH=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||' || echo "main")
MERGE_BASE=$(git merge-base HEAD "$DEFAULT_BRANCH")
YOR_COMMITS=$(git log --format=%H --grep='^ci: update yor tags$' "$MERGE_BASE"..HEAD)
if [[ -n $YOR_COMMITS ]]; then
  echo "Dropping previous yor commits..."
  SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
  GIT_SEQUENCE_EDITOR="$SCRIPT_DIR/yor-rebase-drop" git rebase --interactive "$MERGE_BASE"
fi

GIT_ROOT=$(git rev-parse --show-toplevel)
CMD=$(yq '.yor.script[0]' $GIT_ROOT/.gitlab-ci.yml)

if [[ -z $CMD ]]; then
  CMD="yor tag --directory ."
fi

(
  # shellcheck disable=SC2001
  PATH=$(sed "s+$HOME/bin++g" <<<"$PATH")
  export PATH
  CMD=$(sed "s!^yor!$(which yor)!g" <<<"$CMD")
  CMD=$(sed 's!--validate!!g' <<<"$CMD")
  eval "$CMD"
)

FILES=$(git status --porcelain | grep '.tf' | grep -v 'temp.*.tf' | awk '{print $2}' | tr -s '\n' ' ' || true)
if [[ -z $FILES ]]; then
  exit 0
fi
rm -f ./temp.*.tf
if [[ $COMMIT -eq 0 ]]; then
  exit 0
fi

git commit $NO_VERIFY $FILES --message 'ci: update yor tags'

GIT_ARGS=""
if [[ -n ${FORCE:-} ]]; then
  GIT_ARGS="-f"
fi

if [[ -n ${PUSH:-} ]]; then
  git push $GIT_ARGS
fi
