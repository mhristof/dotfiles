#!/usr/bin/env python3
"""
du-s3
Version: 1.1.0

- Lists all S3 buckets
- Fetches StandardStorage size from CloudWatch
- Prints human-readable sizes
- Sorted by size (largest first; buckets without metrics last)
- Shows a simple progress bar while querying
"""

import sys
import datetime
import boto3


def human_size(num_bytes: float) -> str:
    """Convert a byte count to a human-readable string."""
    if num_bytes <= 0:
        return "0 B"

    units = ["B", "KB", "MB", "GB", "TB", "PB", "EB"]
    size = float(num_bytes)
    for unit in units:
        if size < 1024:
            return f"{size:,.2f} {unit}"
        size /= 1024

    return f"{size:,.2f} ZB"


def get_bucket_size_bytes(cw, bucket_name: str) -> float:
    """
    Query CloudWatch for the bucket's Standard storage size.
    Returns bytes as float, or -1 if metric not available.
    """

    # Use timezone-aware datetimes in UTC to avoid deprecation warnings
    end = datetime.datetime.now(datetime.timezone.utc)
    start = end - datetime.timedelta(days=3)

    resp = cw.get_metric_statistics(
        Namespace="AWS/S3",
        MetricName="BucketSizeBytes",
        Dimensions=[
            {"Name": "BucketName", "Value": bucket_name},
            {"Name": "StorageType", "Value": "StandardStorage"},
        ],
        StartTime=start,
        EndTime=end,
        Period=86400,
        Statistics=["Average"],
    )

    datapoints = resp.get("Datapoints", [])
    if not datapoints:
        return -1

    # Typically one datapoint; take the latest just in case
    latest = max(datapoints, key=lambda d: d["Timestamp"])
    return latest.get("Average", -1)


def print_progress(current: int, total: int, width: int = 40) -> None:
    """Render a simple progress bar on a single line."""
    if total <= 0:
        return

    ratio = current / total
    if ratio < 0:
        ratio = 0
    if ratio > 1:
        ratio = 1

    filled = int(ratio * width)
    bar = "#" * filled + "-" * (width - filled)
    msg = f"\rProcessing buckets: [{bar}] {current}/{total}"
    sys.stdout.write(msg)
    sys.stdout.flush()


def main() -> None:
    s3 = boto3.client("s3")
    cw = boto3.client("cloudwatch")

    buckets = s3.list_buckets().get("Buckets", [])
    if not buckets:
        print("No buckets found.")
        return

    total = len(buckets)
    results = []

    for idx, b in enumerate(buckets, start=1):
        name = b["Name"]
        size_bytes = get_bucket_size_bytes(cw, name)
        results.append((name, size_bytes))
        print_progress(idx, total)

    # Finish progress line
    print()

    # Sort: known sizes first, largest to smallest; buckets without metrics last
    def sort_key(item):
        name, size = item
        if size < 0:
            return (1, 0)  # group with unknown sizes at the end
        return (0, -size)  # sort known sizes by descending byte count

    results_sorted = sorted(results, key=sort_key)

    print("S3 Bucket Sizes (StandardStorage):")
    for name, size in results_sorted:
        if size < 0:
            print(f"{name:40}  metrics not available yet")
            continue
        print(f"{name:40}  {human_size(size):>15}")


if __name__ == "__main__":
    main()
