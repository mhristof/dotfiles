# vi: ft=sh

DIR=$(dirname "$0")
UNAME=$(uname | tr '[:upper:]' '[:lower:]')

function link() {
    local source
    local dest

    source=$1
    dest=$2

    if [[ ! -L $dest ]]; then
        rm -rf "$dest"
    fi

    if [[ -e $dest ]]; then
        return
    fi

    ln -s "$source" "$dest"
}

function install() {
    local command

    command=$1

    case $1 in
        sha256sum) package=coreutils ;;
        timeout) package=coreutils ;;
        *) package=$command ;;
    esac

    which "$command" &>/dev/null || brew install $package
}

function terraform_plan_name() {
    if [[ -n "${TF_DATA_DIR:-}" ]]; then
        suffix="${TF_DATA_DIR#.terraform-}"
        echo "terraform.${suffix}.tfplan"
    elif [[ -n "${TF_CLI_ARGS_plan:-}" ]]; then
        suffix=$(echo "$TF_CLI_ARGS_plan" | grep -oE '[^/]+\.tfvars' | sed 's/\.tfvars//')
        echo "terraform.${suffix}.tfplan"
    else
        echo "terraform.tfplan"
    fi
}
